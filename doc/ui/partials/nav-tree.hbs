<ul class="nav-list">
  {{#each navigation}}
  <li class="nav-item">
    {{#if this.url}}
    <a href="{{{this.url}}}">{{this.content}}</a>
    {{else}}
    <span>{{this.content}}</span>
    {{/if}}
    {{#if this.items}}
    {{> nav-tree navigation=this.items}}
    {{/if}}
  </li>
  {{/each}}
</ul>
